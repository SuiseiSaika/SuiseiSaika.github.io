---
import { withBase } from '../utils/paths';
---

<section class="hero" id="top" aria-labelledby="hero-title">
  <div class="hero-copy">
    <p class="hero-kicker">Software Engineering · AI Applications · Applied ML</p>
    <h1 id="hero-title">Johnson Chen <span>Chang-Shuo Chen</span></h1>
    <p class="hero-role">Software Engineer · AI Applications · Computer Vision</p>
    <p class="hero-summary">
      I build software that connects applied machine learning with real-world applications—from computer-vision pipelines and model evaluation to operator tools, device integration, and edge-AI prototypes.
    </p>
    <p class="hero-direction">
      Open to Software Engineer, AI Application Engineer, ML Engineer, Computer Vision Engineer, and Edge AI roles.
    </p>
    <div class="hero-actions" aria-label="Primary links">
      <a class="button button-primary" href="#projects">Explore projects</a>
      <a class="button button-secondary" href="https://github.com/SuiseiSaika">GitHub</a>
      <a class="button button-secondary" href="https://www.linkedin.com/in/chang-shuo-johnson-chen-83013a193/">LinkedIn</a>
    </div>
  </div>
  <div class="hero-visual" aria-label="Portrait of Johnson Chen (Chang-Shuo Chen)">
    <div class="portrait-frame">
      <img src={withBase('/images/profile.jpeg')} alt="Portrait of Johnson Chen (Chang-Shuo Chen)" width="832" height="1039" />
    </div>
    <div class="availability-card">
      <span class="status-dot" aria-hidden="true"></span>
      <span>Open to software and AI application roles</span>
    </div>
  </div>
</section>
