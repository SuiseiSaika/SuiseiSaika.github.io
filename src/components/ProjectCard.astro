---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const href = withBase(`/projects/${project.id}/`);
---

<article class="project-card reveal">
  <a class="project-image" href={href} aria-label={`View details for ${project.data.title}`}>
    <img src={withBase(project.data.image)} alt={project.data.imageAlt} loading="lazy" width="1200" height="675" />
  </a>
  <div class="project-content">
    <div class="project-meta">
      <span>{project.data.status}</span>
      <span>{project.data.year}</span>
    </div>
    <h3><a href={href}>{project.data.title}</a></h3>
    <p>{project.data.summary}</p>
    <ul class="tag-list" aria-label="Technologies">
      {project.data.tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="card-links">
      <a class="text-link" href={href}>Details</a>
    </div>
  </div>
</article>
