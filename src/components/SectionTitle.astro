---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="section-title reveal">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {description && <p class="section-description">{description}</p>}
</header>
